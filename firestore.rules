rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function matchNotStarted(matchId) {
      let matchDoc = get(/databases/$(database)/documents/matches/$(matchId)).data;
      return matchDoc.isLocked == false && request.time < matchDoc.kickoffTime;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();

      // User can create their own document on first sign-in
      allow create: if isOwner(uid) &&
        request.resource.data.role == 'user' &&
        request.resource.data.onboardingComplete == false;

      // User can update their own document but cannot change role
      allow update: if isOwner(uid) &&
        !('role' in request.resource.data.diff(resource.data).affectedKeys());

      // Admin can write any user document
      allow write: if isAdmin();
    }

    // ── Tournaments ───────────────────────────────────────────────────────────
    match /tournaments/{tournamentId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();

      // ── Leaderboard subcollection ─────────────────────────────────────────
      match /leaderboard/{userId} {
        allow read: if isAuth();
        // Users can create their own leaderboard entry (joining a tournament)
        allow create: if isAuth() && request.auth.uid == userId &&
          request.resource.data.totalPoints == 0 &&
          request.resource.data.rank == 999;
        // Only admin SDK updates scores (via cron)
        allow update, delete: if isAdmin();
      }
    }

    // ── Matches ───────────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isAuth();
      allow write: if isAdmin(); // Only admin SDK writes match data
    }

    // ── Predictions ───────────────────────────────────────────────────────────
    match /predictions/{predictionId} {
      // Users can only read their own predictions, OR anyone can read if the match has started/locked
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        !matchNotStarted(resource.data.matchId)
      );

      // Create: user owns it, match not started, correct ID format
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid &&
        predictionId == request.auth.uid + '_' + request.resource.data.matchId &&
        request.resource.data.pointsEarned == null &&
        matchNotStarted(request.resource.data.matchId);

      // Update: user owns it, match not started, cannot change matchId/tournamentId/userId
      allow update: if isAuth() &&
        resource.data.userId == request.auth.uid &&
        matchNotStarted(resource.data.matchId) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.matchId == resource.data.matchId &&
        request.resource.data.tournamentId == resource.data.tournamentId &&
        request.resource.data.pointsEarned == null;

      // Predictions are never deleted
      allow delete: if false;

      // Admin SDK can update (for score evaluation)
      // Note: Admin SDK bypasses these rules server-side
    }

    // ── API Meta (league cache) ───────────────────────────────────────────────
    match /apiMeta/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
